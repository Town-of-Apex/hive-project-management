# Copy to .env for local development (host run via run_dev.ps1)

BASE_PATH=

DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/apex_db
ALLOW_SQLITE_FALLBACK=false
FALLBACK_DATABASE_URL=sqlite:///./data/app.db

JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRE_MINUTES=480

PORT=8080
